# -*- Python -*-
"""Lit site configuration for BlockType tests (generated by CMake)."""

import os

# Binary directory (set by CMake)
config.binary_dir = "@CMAKE_BINARY_DIR@"

# Source directory (set by CMake)
config.source_dir = "@CMAKE_SOURCE_DIR@"

# Include the main configuration
lit_config.load_config(
    config,
    os.path.join(config.source_dir, 'tests', 'lit', 'lit.cfg.py')
)
