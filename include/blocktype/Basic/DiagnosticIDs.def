//===----------------------------------------------------------------------===//
//
// This file defines diagnostic IDs for the BlockType compiler.
//
//===----------------------------------------------------------------------===//

#ifndef DIAG
#define DIAG(ID, Level, Text)
#endif

//===----------------------------------------------------------------------===//
// Lexer Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_lex_invalid_char, Error, "invalid character in source code")
DIAG(err_lex_invalid_identifier_start, Error, "invalid Unicode character in identifier start")
DIAG(err_lex_unterminated_char, Error, "unterminated character constant")
DIAG(err_lex_unterminated_string, Error, "unterminated string literal")
DIAG(err_lex_unterminated_raw_string, Error, "unterminated raw string literal")
DIAG(err_lex_invalid_raw_string, Error, "invalid raw string literal delimiter")
DIAG(err_lex_unterminated_block_comment, Error, "unterminated block comment")
DIAG(err_lex_invalid_utf8, Error, "invalid UTF-8 sequence")

//===----------------------------------------------------------------------===//
// Preprocessor Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_pp_unexpected_eof, Error, "unexpected end of file in preprocessor directive")
DIAG(err_pp_invalid_directive, Error, "invalid preprocessor directive")
DIAG(err_pp_expected_filename, Error, "expected filename after #include")
DIAG(err_pp_expected_macro_name, Error, "expected macro name")
DIAG(err_pp_macro_not_identifier, Error, "macro name must be an identifier")
DIAG(err_pp_unterminated_macro_params, Error, "unterminated macro parameter list")
DIAG(err_pp_unterminated_macro_args, Error, "unterminated macro argument list")
DIAG(err_pp_file_not_found, Error, "file not found")
DIAG(err_pp_cannot_read_file, Error, "cannot read file")
DIAG(err_pp_circular_include, Error, "circular inclusion detected")
DIAG(err_pp_if_without_endif, Error, "#if without #endif")
DIAG(err_pp_elif_without_if, Error, "#elif without #if")
DIAG(err_pp_else_without_if, Error, "#else without #if")
DIAG(err_pp_endif_without_if, Error, "#endif without #if")
DIAG(err_pp_duplicate_else, Error, "duplicate #else")
DIAG(err_pp_elif_after_else, Error, "#elif after #else")

DIAG(warn_pp_include_not_implemented, Warning, "#include not fully implemented")
DIAG(warn_pp_embed_not_implemented, Warning, "#embed not implemented yet")

DIAG(note_pp_macro_defined_here, Note, "macro defined here")

//===----------------------------------------------------------------------===//
// General Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_unknown, Error, "unknown error")
DIAG(err_not_implemented, Error, "feature not implemented")

#undef DIAG
